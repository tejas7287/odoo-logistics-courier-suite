<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--         Wizard Form -->
        <record id="view_handoff_wizard_form" model="ir.ui.view">
            <field name="name">handoff.wizard.form</field>
            <field name="model">handoff.wizard</field>
            <field name="arch" type="xml">
                <form string="Create Handoff">
                    <sheet>
                        <group>
                            <group>
                                <!-- ✅ ALL OPERATION TYPES -->
                                <field name="picking_type_id"/>

                                <!-- ✅ PICKINGS BASED ON OPERATION -->
                                <field name="picking_id"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"/>
                                <!--                                <field name="sale_id" readonly="1"/>-->
                                <field name="name" readonly="1"/>
                                <!--                                <field name="state"/>-->
                            </group>

                            <group>
                                <field name="vehicle_number" invisible="internal != 1"/>
                                <field name="driver_id" invisible="internal != 1"/>
                                <field name="vehicle_id" invisible="internal != 1"/>
                                <!--                                <field name="courier_partner_id"/>-->
                                <!--                                <field name="manifest_ref"/>-->
                            </group>
                        </group>

                        <group>
                            <field name="parcel_count"/>
                            <field name="assigned_datetime" invisible="internal != 1"/>

                            <field name="picked_datetime"/>
                            <!--                            <field name="awb_number"/>-->
                            <field name="serviced_by_id" readonly="1"/>
                            <field name="authorized_person" invisible=" internal ==1 "/>
                        </group>

                        <group>
                            <field name="notes" colspan="2"/>
                        </group>

                        <footer>
                            <button string="Confirm"
                                    type="object"
                                    name="action_confirm_handoff"
                                    class="btn-primary"
                                    confirm="Are you sure you want to confirm the handoff? Once confirmed, products will be moved to the selected location."/>
                            <button string="Cancel"
                                    class="btn-secondary"
                                    special="cancel"/>
                            <!--                            <button string="Print"-->
                            <!--                                    type="object"-->
                            <!--                                    name="action_print_handoff_wizard"-->
                            <!--                                    icon="fa-print"-->
                            <!--                                    class="btn-secondary"/>-->
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>


        <!-- Act Window -->
        <record id="action_handoff_wizard" model="ir.actions.act_window">
            <field name="name">Create Handoff</field>
            <field name="res_model">handoff.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_handoff_wizard_form"/>
            <field name="target">new</field>
        </record>

