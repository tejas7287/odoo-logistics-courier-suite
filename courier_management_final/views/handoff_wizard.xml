    'type': 'ir.actions.act_window',
    'name': 'Create Handoff',
    'res_model': 'handoff.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {
        'default_picking_id': active_id,
        'active_ids': active_ids,
        'active_id': active_id,
    },
}
    ]]></field>
