        <record id="action_delivery_create_handoff" model="ir.actions.server">
            <field name="name">Create Handoff</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_view_types">form,list</field>
            <field name="state">code</field>
            <field name="code"><![CDATA[
active_ids = env.context.get('active_ids') or []
active_id = env.context.get('active_id') or (active_ids[0] if active_ids else False)

