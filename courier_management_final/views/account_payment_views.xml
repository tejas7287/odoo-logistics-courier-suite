<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_inherit_hide_reset_button" model="ir.ui.view">
        <field name="name">account.payment.form.hide.reset.button</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">

            <!-- Override Reset to Draft button visibility -->
            <xpath expr="//header/button[@name='action_draft']" position="attributes">
                <attribute name="invisible">state in ('draft','paid')</attribute>
            </xpath>

        </field>
    </record>
</odoo>
