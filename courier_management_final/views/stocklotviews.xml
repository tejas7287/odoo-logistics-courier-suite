<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- FORM view: insert fields after 'ref' field -->
    <record id="view_stock_lot_form_inherit_awb_barcode" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.awb.delivery.barcode</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="awb_number"/>
                <field name="delivery_order"/>
                <field name="barcode_number"/>
            </xpath>
        </field>
    </record>

    <!-- LIST (tree) view: add columns after 'name' column -->
    <record id="view_stock_lot_tree_inherit_awb_barcode" model="ir.ui.view">
        <field name="name">stock.lot.tree.inherit.awb.delivery.barcode</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="awb_number"/>
                <field name="delivery_order"/>
                <field name="barcode_number"/>
            </xpath>
        </field>
    </record>

</odoo>
