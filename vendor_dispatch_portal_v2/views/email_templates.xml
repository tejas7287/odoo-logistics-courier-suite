<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Mail templates declared in NOUPDATE block -->
    <data noupdate="1">

        <!-- Customer Dispatch Notification -->
        <record id="email_vendor_dispatch_confirmed" model="mail.template">
            <field name="name">Customer Dispatch Notification</field>
            <field name="model_id" ref="stock.model_stock_picking"/>

            <!-- FROM -->
            <field name="email_from">
                {{ object.company_id.email_formatted or user.email_formatted }}
            </field>

            <!-- ✅ TO: SAME CUSTOMER EMAIL AS PORTAL PAGE -->
            <!-- shipping email first, billing email fallback -->
            <field name="email_to">
                {{ object.sale_id.partner_shipping_id.email
                   or object.sale_id.partner_id.email }}
            </field>
            <field name="use_default_to" eval="False"/>

            <!-- SUBJECT -->
            <field name="subject">
                {{ object.company_id.name }} – Your Order {{ object.name }} Has Been Dispatched
            </field>

            <field name="description">
                Sent to customer when vendor submits dispatch details
            </field>

            <!-- BODY -->
            <field name="body_html" type="html">
                <div style="margin:0;padding:0;">
                    <p style="margin:0;padding:0;font-size:13px;">

                        Dear
                        <t t-out="object.sale_id.partner_shipping_id.name
                                  or object.sale_id.partner_id.name"/>,
                        <br/><br/>

                        Your order
                        <strong t-out="object.name"/>
                        has been successfully dispatched.
                        <br/><br/>

                        <t t-if="object.vendor_dispatch_location_id">
                            <strong>Dispatch Location:</strong>
                            <t t-out="object.vendor_dispatch_location_id.complete_name"/>
                            <br/>
                        </t>

                        <t t-if="object.vendor_expected_delivery_date">
                            <strong>Expected Delivery Date:</strong>
                            <t t-out="object.vendor_expected_delivery_date"/>
                            <br/>
                        </t>

                        <t t-if="object.vendor_carrier_id or object.vendor_carrier_name">
                            <strong>Carrier:</strong>
                            <t t-out="object.vendor_carrier_id.name or object.vendor_carrier_name"/>
                            <br/>
                        </t>

                        <t t-if="object.vendor_tracking_number">
                            <strong>Tracking Number:</strong>
                            <t t-out="object.vendor_tracking_number"/>
                            <br/>
                        </t>

                        <br/>
                        Do not hesitate to contact us if you have any questions.
                        <br/><br/>

                        <t t-if="not is_html_empty(user.signature)">
                            <div>
                                --<br/>
                                <t t-out="user.signature"/>
                            </div>
                        </t>

                    </p>
                </div>
            </field>

            <field name="auto_delete" eval="True"/>

        </record>

    </data>
</odoo>
