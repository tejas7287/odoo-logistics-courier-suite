<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Partner Form Extension -->
    <record id="view_partner_form_inherit_vendor" model="ir.ui.view">
        <field name="name">res.partner.form.vendor.portal</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Place vendor_portal checkbox under Sales & Purchase section -->
            <xpath expr="//notebook/page[@name='sales_purchases']//group" position="inside">
                <group string="Vendor Portal Access">
                    <field name="vendor_portal" widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>


    <record id="view_picking_form_vendor_dispatch_security" model="ir.ui.view">
        <field name="name">stock.picking.form.vendor.dispatch.security</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Replace the original shipping block (carrier_data) with vendor fields.
                 Editable group: only for vendor portal users (your custom group).
                 Read-only group: for internal users (admins, stock, purchase, sales, account). -->
            <xpath expr="//group[@name='carrier_data']" position="replace">
                <group name="carrier_data" string="Shipping Information">
                    <!-- Editable by vendors (portal users) -->
                    <group groups="vendor_dispatch_portal_v2.group_vendor_portal_user">

                        <field name="vendor_dispatch_location_id"/>
                        <field name="vendor_expected_delivery_date"/>
                        <field name="vendor_carrier_id"/>



                        <field name="vendor_carrier_name"/>
                        <field name="vendor_tracking_number"/>
                        <field name="vendor_dispatch_reference"/>
                        <field name="vendor_dispatch_date"/>
                        <field name="vendor_invoice_number"/>
                        <field name="vendor_payment_status"/>
                        <field name="vendor_delivery_status"/>
                        <field name="vendor_notes"/>
                    </group>

                    <!-- Visible to internal users but read-only -->
                    <group groups="base.group_user,base.group_system,stock.group_stock_user,purchase.group_purchase_user,sales_team.group_sale_salesman,account.group_account_user">
                        <field name="vendor_dispatch_location_id" readonly="1"/>
                        <field name="vendor_expected_delivery_date" readonly="1"/>
                        <field name="vendor_carrier_id" readonly="1"/>
                        <field name="vendor_sale_order_id" readonly="1"/>
                        <field name="vendor_purchase_order_id" readonly="1"/>



                        <field name="vendor_carrier_name" readonly="1"/>
                        <field name="vendor_tracking_number" readonly="1"/>
                        <field name="vendor_dispatch_reference" readonly="1"/>
                        <field name="vendor_dispatch_date" readonly="1"/>
                        <field name="vendor_invoice_number" readonly="1"/>
                        <field name="vendor_payment_status" readonly="1"/>
                        <field name="vendor_delivery_status" readonly="1"/>
                        <field name="vendor_notes" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>


</odoo>
